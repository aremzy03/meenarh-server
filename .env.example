PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=meenarh_logistics
DB_PORT=3306
JWT_SECRET=change-this-to-a-strong-secret
NODE_ENV=development

# Paystack (https://paystack.com/docs/payments/test-payments)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
# Public URL of the Next.js app (no trailing slash). Used for Paystack callback_url.
APP_PUBLIC_URL=http://localhost:3000

# Public URL of the API (no trailing slash). Used for email verification links.
API_PUBLIC_URL=http://localhost:5000

# Resend (https://resend.com)
# Used for transactional emails (order confirmation, status updates, password reset, email verification).
# Get the API key from https://resend.com/api-keys. The `EMAIL_FROM` domain must be verified in Resend.
# In dev with no verified domain, you can use `onboarding@resend.dev` BUT it can only deliver to your Resend account email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Meenarh Logistics <noreply@your-verified-domain.com>

# CORS allowlist (comma-separated; no trailing slashes). Recommended to set in production.
FRONTEND_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3000
