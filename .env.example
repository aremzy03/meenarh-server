PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=meenarh_logistics
DB_PORT=3306
JWT_SECRET=change-this-to-a-strong-secret
NODE_ENV=development

# Paystack (https://paystack.com/docs/payments/test-payments)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
# Public URL of the Next.js app (no trailing slash). Used for Paystack callback_url.
APP_PUBLIC_URL=http://localhost:3000

# Public URL of the API (no trailing slash). Used for WhatsApp verify links.
API_PUBLIC_URL=http://localhost:5000

# WhatsApp Cloud API (Meta Graph API)
# Get these from your Meta App (WhatsApp product) -> API Setup.
# Note: never commit real tokens; keep them only in your local/production .env.
WHATSAPP_ACCESS_TOKEN=EAAGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Optional overrides (defaults are used if omitted)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_API_BASE_URL=https://graph.facebook.com

# CORS allowlist (comma-separated; no trailing slashes). Recommended to set in production.
FRONTEND_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3000
